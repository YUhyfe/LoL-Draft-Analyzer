                    <Label text="9" styleClass="rank-position"/>
                    <Region prefWidth="40" prefHeight="40" minWidth="40" minHeight="40" maxWidth="40" maxHeight="40"
                            style="-fx-background-color: linear-gradient(to bottom right, #A78BFA, #6D28D9); -fx-background-radius: 999;"/>
                    <VBox HBox.hgrow="ALWAYS" spacing="2">
                        <Label text="Doinb" styleClass="text-bold text-gold"/>
