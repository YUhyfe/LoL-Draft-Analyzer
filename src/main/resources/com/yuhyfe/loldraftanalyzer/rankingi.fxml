                    <Label text="10" styleClass="rank-position"/>
                    <Region prefWidth="40" prefHeight="40" minWidth="40" minHeight="40" maxWidth="40" maxHeight="40"
                            style="-fx-background-color: linear-gradient(to bottom right, #00F5D4, #0397AB); -fx-background-radius: 999;"/>
