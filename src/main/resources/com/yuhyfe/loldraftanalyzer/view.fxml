<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.StackPane?>


<BorderPane minHeight="680.0" minWidth="1024.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.yuhyfe.loldraftanalyzer.controller.MainController">
   <top>
      <HBox prefHeight="70.0" prefWidth="200.0" styleClass="top-bar" BorderPane.alignment="CENTER_LEFT">
         <children>
            <Label styleClass="app-logo" text="⚔ DRAFT" />
            <Label styleClass="app-logo-accent" text="ANALYZER" />
            <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
            <Button fx:id="navProfil" mnemonicParsing="false" text="Profil">
               <styleClass>
                  <String fx:value="nav-tab" />
                  <String fx:value="active" />
               </styleClass>
            </Button>
            <Button fx:id="navBohaterowie" mnemonicParsing="false" styleClass="nav-tab" text="Bohaterowie" />
            <Button fx:id="navMeta" mnemonicParsing="false" styleClass="nav-tab" text="Meta" />
            <Button fx:id="navMecze" mnemonicParsing="false" styleClass="nav-tab" text="Mecze" />
            <Button fx:id="navRankingi" mnemonicParsing="false" styleClass="nav-tab" text="Rankingi" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnSettings" mnemonicParsing="false" styleClass="icon-btn" text="⚙" />
         </children>
      </HBox>
   </top>
   <center>
      <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent;" BorderPane.alignment="CENTER">
         <StackPane fx:id="contentArea" styleClass="content-area" />
      </ScrollPane>
   </center>
   <bottom>
      <HBox prefHeight="32.0" prefWidth="200.0" style="-fx-background-color: #06121C; -fx-padding: 6 24 6 24; -fx-border-color: -hex-border-soft; -fx-border-width: 1 0 0 0;" BorderPane.alignment="CENTER_RIGHT">
         <children>
            <Label text="v0.1.0 · Patch 14.X · LCU: connected">
               <styleClass>
                  <String fx:value="text-muted" />
                  <String fx:value="text-sm" />
               </styleClass>
            </Label>
         </children>
      </HBox>
   </bottom>
</BorderPane>
