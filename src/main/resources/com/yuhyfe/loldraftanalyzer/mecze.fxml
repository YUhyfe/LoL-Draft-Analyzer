-->

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      stylesheets="@styles.css"
      styleClass="content-area"
      spacing="20"
      prefWidth="1840"
      prefHeight="980"
      maxWidth="1700">
    <padding>
        <Insets top="8" right="0" bottom="8" left="0"/>
    </padding>

    <!-- HEADER -->
    <HBox spacing="20" alignment="CENTER_LEFT">
        <Label text="Historia meczów" styleClass="page-title"/>
        <Label text="247 meczów  ·  ostatnie 30 dni" styleClass="text-muted text-sm"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField promptText="Filtruj po nicku / czempionie..." styleClass="search-field" prefWidth="320"/>
    </HBox>

    <!-- FILTERS -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="Wszystkie" styleClass="filter-chip active"/>
        <Button text="Solo/Duo" styleClass="filter-chip"/>
        <Button text="Flex" styleClass="filter-chip"/>
        <Button text="Normal" styleClass="filter-chip"/>
        <Button text="ARAM" styleClass="filter-chip"/>
        <Button text="Clash" styleClass="filter-chip"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Wynik:" styleClass="text-muted text-sm"/>
        <ComboBox prefWidth="140" value="Wszystkie">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="Wszystkie"/>
                    <String fx:value="Tylko wygrane"/>
                    <String fx:value="Tylko przegrane"/>
                </FXCollections>
            </items>
        </ComboBox>
        <Label text="Okres:" styleClass="text-muted text-sm"/>
        <ComboBox prefWidth="160" value="Ostatnie 30 dni">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="Dzisiaj"/>
                    <String fx:value="Ostatnie 7 dni"/>
                    <String fx:value="Ostatnie 30 dni"/>
                    <String fx:value="Bieżący sezon"/>
                    <String fx:value="Wszystkie"/>
                </FXCollections>
            </items>
        </ComboBox>
    </HBox>

    <!-- KPI STRIP -->
    <HBox spacing="16">
        <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
            <Label text="148W / 99L" styleClass="kpi-value kpi-value-success"/>
            <Label text="BILANS OKRESU" styleClass="kpi-label"/>
