<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
  mecze.fxml — historia meczów gracza z filtrami.
-->

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.yuhyfe.loldraftanalyzer.controller.MeczeController"
      stylesheets="@styles.css"
      styleClass="content-area"
      spacing="20">

    <!-- HEADER -->
    <HBox spacing="16" alignment="CENTER_LEFT">
        <Label text="Historia meczów" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button onAction="#handleRefresh" styleClass="btn-ghost" text="↻ Odśwież"/>
    </HBox>

    <!-- FILTERS -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="btnAll" onAction="#handleAll" text="Wszystkie">
            <styleClass><String fx:value="filter-chip"/><String fx:value="active"/></styleClass>
        </Button>
        <Button fx:id="btnSolo"   onAction="#handleSolo"   text="Solo/Duo"   styleClass="filter-chip"/>
        <Button fx:id="btnFlex"   onAction="#handleFlex"   text="Flex"       styleClass="filter-chip"/>
        <Button fx:id="btnNormal" onAction="#handleNormal" text="Normal"     styleClass="filter-chip"/>
        <Button fx:id="btnAram"   onAction="#handleAram"   text="ARAM"       styleClass="filter-chip"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Wynik:" styleClass="text-muted text-sm"/>
        <ComboBox fx:id="resultCombo" prefWidth="160">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="Wszystkie"/>
                    <String fx:value="Tylko wygrane"/>
                    <String fx:value="Tylko przegrane"/>
                </FXCollections>
            </items>
        </ComboBox>
    </HBox>

    <!-- KPI STRIP -->
    <HBox spacing="16">
        <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
            <Label fx:id="kpiRecord" text="—" styleClass="kpi-value"/>
            <Label text="BILANS" styleClass="kpi-label"/>
        </VBox>
        <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
            <Label fx:id="kpiWr" text="—" styleClass="kpi-value"/>
            <Label text="WIN RATE" styleClass="kpi-label"/>
        </VBox>
        <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
            <Label fx:id="kpiKda" text="—" styleClass="kpi-value"/>
            <Label text="ŚREDNIE KDA" styleClass="kpi-label"/>
        </VBox>
        <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
            <Label fx:id="kpiAvgTime" text="—" styleClass="kpi-value kpi-value-info"/>
            <Label text="ŚREDNI CZAS GRY" styleClass="kpi-label"/>
        </VBox>
    </HBox>

    <!-- MATCH LIST -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                minHeight="0"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background: transparent; -fx-background-color: transparent;">
        <VBox fx:id="matchListContainer" spacing="10">
            <padding><Insets top="4" bottom="4"/></padding>
        </VBox>
    </ScrollPane>

    <!-- STATUS BAR -->
    <HBox prefHeight="32"
          style="-fx-background-color: #06121C; -fx-padding: 6 24 6 24; -fx-border-color: -hex-border-soft; -fx-border-width: 1 0 0 0;">
        <Label fx:id="statusLabel" text="ładowanie...">
            <styleClass>
                <String fx:value="text-muted"/>
                <String fx:value="text-sm"/>
            </styleClass>
        </Label>
    </HBox>

</VBox>
