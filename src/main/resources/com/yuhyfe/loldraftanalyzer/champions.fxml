<!--
  champions.fxml — siatka wszystkich postaci z filtrowaniem i sortowaniem.
  Root: VBox. Wkładany do StackPane content-area w view.fxml przez fx:include.
-->

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      stylesheets="@styles.css"
      styleClass="content-area"
      spacing="20"
      prefWidth="1840"
      prefHeight="980"
      maxWidth="1700">
    <padding>
        <Insets top="8" right="0" bottom="8" left="0"/>
    </padding>

    <!-- =========================================================
         HEADER: tytuł + licznik + search
         ========================================================= -->
    <HBox spacing="20" alignment="CENTER_LEFT">
        <Label text="Bohaterowie" styleClass="page-title"/>
        <Label text="168 z 168 postaci  ·  Patch 14.X" styleClass="text-muted text-sm"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField promptText="Szukaj postaci..." styleClass="search-field" prefWidth="320"/>
    </HBox>

    <!-- =========================================================
         FILTERS: role chips + sort dropdown
         ========================================================= -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="Wszystkie" styleClass="filter-chip active"/>
        <Button text="TOP" styleClass="filter-chip"/>
        <Button text="JUNGLE" styleClass="filter-chip"/>
        <Button text="MID" styleClass="filter-chip"/>
        <Button text="ADC" styleClass="filter-chip"/>
        <Button text="SUPPORT" styleClass="filter-chip"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Sortuj według:" styleClass="text-muted text-sm"/>
        <ComboBox prefWidth="160" value="Tier">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="Tier"/>
                    <String fx:value="Winrate"/>
                    <String fx:value="Pickrate"/>
                    <String fx:value="Banrate"/>
                    <String fx:value="Alfabetycznie"/>
                </FXCollections>
            </items>
        </ComboBox>
    </HBox>

    <!-- =========================================================
         KPI STRIP — szybki przegląd mety
         ========================================================= -->
    <HBox spacing="16">
        <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
            <Label text="5" styleClass="kpi-value" style="-fx-text-fill: #FF006E;"/>
            <Label text="POSTACI W S+ TIER" styleClass="kpi-label"/>
        </VBox>
        <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
            <Label text="10" styleClass="kpi-value kpi-value-success"/>
            <Label text="POSTACI W S TIER" styleClass="kpi-label"/>
        </VBox>
        <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
            <Label text="JUNGLE" styleClass="kpi-value kpi-value-info"/>
            <Label text="DOMINUJĄCA ROLA" styleClass="kpi-label"/>
        </VBox>
        <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
            <Label text="50.4%" styleClass="kpi-value kpi-value-warn"/>
            <Label text="ŚREDNI WINRATE META" styleClass="kpi-label"/>
        </VBox>
    </HBox>

